project_id = "your-gcp-project-id"
region     = "us-central1"

# Optional: service account used by backend runtime (Cloud Run/GKE/VM).
backend_service_account_email = "backend-sa@your-gcp-project-id.iam.gserviceaccount.com"

# Recommended hybrid mode:
# - false: Terraform creates secret containers only (no secret values in tfstate).
# - true: Terraform also creates secret versions from values below.
create_secret_versions = false

# Only used when create_secret_versions = true.
google_oauth_client_id     = "replace-with-oauth-client-id"
google_oauth_client_secret = "replace-with-oauth-client-secret"

# Must match the redirect URI configured in Google OAuth client.
google_oauth_redirect_uri = "https://your-api-domain.com/oauth/google/callback"
